/* styles/animations.wxss - 动效样式（积分动画/加载动画） */

/* ========== 积分变动动画 ========== */
.points-change-anim {
  animation: points-pop var(--duration-slow) var(--ease-spring);
}

@keyframes points-pop {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 积分飞入动画 */
.points-fly-in {
  animation: points-fly var(--duration-slow) var(--ease-out);
}

@keyframes points-fly {
  0% {
    transform: translateY(-30px) scale(0.5);
    opacity: 0;
  }
  60% {
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* 积分增加动画（绿色闪现） */
.points-add-flash {
  animation: points-add var(--duration-normal) var(--ease-out);
}

@keyframes points-add {
  0% {
    color: var(--color-success);
    transform: scale(1.3);
  }
  100% {
    color: var(--color-text-primary);
    transform: scale(1);
  }
}

/* 积分减少动画（红色闪现） */
.points-minus-flash {
  animation: points-minus var(--duration-normal) var(--ease-out);
}

@keyframes points-minus {
  0% {
    color: var(--color-error);
    transform: scale(1.3);
  }
  100% {
    color: var(--color-text-primary);
    transform: scale(1);
  }
}

/* ========== 加载动画 ========== */
.loading-spinner {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
}

.loading-spinner::after {
  content: '';
  width: 20px;
  height: 20px;
  border: 2px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-circle);
  animation: spin var(--duration-normal) linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 大号加载 */
.loading-spinner-lg {
  width: 40px;
  height: 40px;
}

.loading-spinner-lg::after {
  width: 36px;
  height: 36px;
  border-width: 3px;
}

/* 脉冲加载 */
.loading-pulse {
  animation: pulse var(--duration-slow) var(--ease-in-out) infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}

/* 三点跳动加载 */
.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
}

.loading-dot {
  width: 6px;
  height: 6px;
  background-color: var(--color-primary);
  border-radius: var(--radius-round);
  animation: dot-bounce var(--duration-slow) var(--ease-in-out) infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes dot-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ========== VIP金色动画 ========== */
.vip-shine {
  animation: vip-shimmer var(--duration-slow) var(--ease-in-out) infinite;
}

@keyframes vip-shimmer {
  0%, 100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

.vip-badge-anim {
  animation: vip-badge-pop var(--duration-normal) var(--ease-spring);
}

@keyframes vip-badge-pop {
  0% {
    transform: scale(0) rotate(-45deg);
    opacity: 0;
  }
  60% {
    transform: scale(1.2) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

/* ========== 卡片入场动画 ========== */
.card-enter {
  animation: card-slide-in var(--duration-normal) var(--ease-out);
}

@keyframes card-slide-in {
  0% {
    transform: translateY(20px);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.card-enter-delay-1 {
  animation-delay: 0.1s;
}

.card-enter-delay-2 {
  animation-delay: 0.2s;
}

.card-enter-delay-3 {
  animation-delay: 0.3s;
}

/* ========== Toast弹出动画 ========== */
.toast-pop {
  animation: toast-appear var(--duration-normal) var(--ease-spring);
}

@keyframes toast-appear {
  0% {
    transform: translateY(100%) scale(0.8);
    opacity: 0;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* ========== 模态弹窗动画 ========== */
.modal-enter {
  animation: modal-slide-up var(--duration-normal) var(--ease-out);
}

@keyframes modal-slide-up {
  0% {
    transform: translateY(100%);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-overlay-enter {
  animation: modal-overlay-fade var(--duration-normal) var(--ease-out);
}

@keyframes modal-overlay-fade {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

/* ========== 渐变闪烁效果 ========== */
.fade-in {
  animation: fade-in var(--duration-normal) var(--ease-out);
}

@keyframes fade-in {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

.fade-out {
  animation: fade-out var(--duration-normal) var(--ease-out);
}

@keyframes fade-out {
  0% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

/* ========== 签到按钮动画 ========== */
.sign-btn-pulse {
  animation: sign-pulse 1.5s var(--ease-in-out) infinite;
}

@keyframes sign-pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(232, 0, 45, 0.4);
  }
  50% {
    box-shadow: 0 0 0 10px rgba(232, 0, 45, 0);
  }
}

/* ========== 数字滚动效果 ========== */
.number-roll {
  animation: number-increment var(--duration-normal) var(--ease-out);
}

@keyframes number-increment {
  0% {
    transform: translateY(10px);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}
