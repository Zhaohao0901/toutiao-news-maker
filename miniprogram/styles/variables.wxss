/* styles/variables.wxss - CSS变量定义（颜色/字号/间距/圆角） */

/* ========== 颜色变量 ========== */
:root {
  --color-primary: #E8002D;
  --color-primary-light: #FF4D6A;
  --color-primary-dark: #C40024;
  --color-primary-alpha-10: rgba(232, 0, 45, 0.1);
  --color-primary-alpha-20: rgba(232, 0, 45, 0.2);
  --color-primary-alpha-50: rgba(232, 0, 45, 0.5);

  --color-text-primary: #1A1A1A;
  --color-text-secondary: #666666;
  --color-text-placeholder: #999999;
  --color-text-white: #FFFFFF;
  --color-text-link: #E8002D;

  --color-bg: #F5F5F5;
  --color-bg-white: #FFFFFF;
  --color-bg-dark: #333333;

  --color-card: #FFFFFF;
  --color-card-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);

  --color-vip-gold: #FAAD14;
  --color-vip-gold-light: #FFE58F;
  --color-vip-gold-bg: rgba(250, 173, 20, 0.1);

  --color-success: #07C160;
  --color-success-light: rgba(7, 193, 96, 0.1);

  --color-warning: #FAAD14;
  --color-warning-light: rgba(250, 173, 20, 0.1);

  --color-error: #E8002D;
  --color-error-light: rgba(232, 0, 45, 0.1);

  --color-divider: #EEEEEE;
  --color-border: #DDDDDD;
  --color-border-light: #F0F0F0;

  --color-tag-bg: #F0F0F0;
  --color-tag-text: #666666;
  --color-tag-primary-bg: rgba(232, 0, 45, 0.1);
  --color-tag-primary-text: #E8002D;

  --color-overlay: rgba(0, 0, 0, 0.5);
  --color-overlay-light: rgba(0, 0, 0, 0.3);
}

/* ========== 字号变量 ========== */
:root {
  --font-size-xs: 10px;
  --font-size-sm: 12px;
  --font-size-base: 14px;
  --font-size-md: 16px;
  --font-size-lg: 18px;
  --font-size-xl: 20px;
  --font-size-xxl: 24px;
  --font-size-display: 32px;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-bold: 700;

  --line-height-tight: 1.2;
  --line-height-normal: 1.6;
  --line-height-relaxed: 1.8;
}

/* ========== 间距变量 ========== */
:root {
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-xxl: 24px;
  --spacing-xxxl: 32px;
  --spacing-page: 16px;

  --padding-card: 16px;
  --padding-section: 16px;
  --padding-cell: 12px 16px;
}

/* ========== 圆角变量 ========== */
:root {
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-round: 50%;
  --radius-circle: 999px;

  --radius-card: 12px;
  --radius-button: 8px;
  --radius-tag: 4px;
  --radius-avatar: 50%;
}

/* ========== 尺寸变量 ========== */
:root {
  --size-avatar-sm: 32px;
  --size-avatar-md: 48px;
  --size-avatar-lg: 64px;
  --size-avatar-xl: 80px;

  --size-icon-sm: 16px;
  --size-icon-md: 24px;
  --size-icon-lg: 32px;

  --size-tabbar: 50px;
  --size-navbar: 44px;

  --width-card: 100%;
  --width-content: 100%;
  --max-width: 750px;
}

/* ========== 阴影变量 ========== */
:root {
  --shadow-sm: 0 1px 4px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 4px 24px rgba(0, 0, 0, 0.12);
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-tabbar: 0 -1px 6px rgba(0, 0, 0, 0.05);
}

/* ========== 动画变量 ========== */
:root {
  --duration-fast: 0.15s;
  --duration-normal: 0.3s;
  --duration-slow: 0.5s;

  --ease-in: ease-in;
  --ease-out: ease-out;
  --ease-in-out: ease-in-out;
  --ease-spring: cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* ========== Z-index层级 ========== */
:root {
  --z-normal: 1;
  --z-sticky: 10;
  --z-fixed: 100;
  --z-modal: 500;
  --z-overlay: 1000;
  --z-toast: 2000;
}
