<!-- components/points-card/points-card.wxml - 积分余额展示卡片 -->
<view class="points-card">
  <!-- 积分余额区域 -->
  <view class="points-card-balance">
    <view class="points-card-balance-row flex-between">
      <view class="points-card-balance-info">
        <text class="points-card-balance-label">当前积分</text>
        <text class="points-card-balance-number {{isAnimating ? 'points-add-flash' : ''}}">{{pointsBalance}}</text>
      </view>
      <view class="points-card-vip-info" wx:if="{{isVip}}">
        <text class="tag tag-vip vip-shine">VIP会员</text>
      </view>
    </view>
    <!-- 进度条 -->
    <view class="points-card-progress" wx:if="{{showProgress}}">
      <view class="points-card-progress-bar">
        <view class="points-card-progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <text class="points-card-progress-text">{{progressText}}</text>
    </view>
  </view>

  <!-- 快捷操作区域 -->
  <view class="points-card-actions" wx:if="{{showActions}}">
    <view class="flex-row">
      <view class="points-card-action" bindtap="onSignIn">
        <text class="points-card-action-icon">✅</text>
        <text class="points-card-action-label">每日签到</text>
        <text class="points-card-action-reward">+3分</text>
      </view>
      <view class="points-card-action" bindtap="onWatchAd">
        <text class="points-card-action-icon">📺</text>
        <text class="points-card-action-label">看广告</text>
        <text class="points-card-action-reward">+2分</text>
      </view>
      <view class="points-card-action" bindtap="onBuyPoints">
        <text class="points-card-action-icon">💰</text>
        <text class="points-card-action-label">购买积分</text>
        <text class="points-card-action-reward">优惠</text>
      </view>
    </view>
  </view>
</view>
