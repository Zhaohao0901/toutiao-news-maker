/* components/business/sign-in-card/sign-in-card.wxss - 签到打卡样式 */
.sign-in-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.consecutive-days {
  font-size: 24rpx;
  color: #E8002D;
  font-weight: bold;
}

.week-progress {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.day-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.day-item.signed .day-circle {
  background-color: #07C160;
}

.day-item.is-today .day-circle {
  border: 4rpx solid #E8002D;
}

.check-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.day-text {
  font-size: 24rpx;
  color: #999999;
}

.day-label {
  font-size: 20rpx;
  color: #999999;
}

.day-item.signed .day-label {
  color: #07C160;
}

.sign-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8002D 0%, #FF4D6A 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.sign-btn.signed {
  background: #CCCCCC;
}
