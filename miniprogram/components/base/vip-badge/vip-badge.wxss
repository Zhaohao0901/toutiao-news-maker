/* components/base/vip-badge/vip-badge.wxss - VIP角标样式 */
.vip-badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FAAD14 0%, #D48806 100%);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  gap: 4rpx;
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
}
