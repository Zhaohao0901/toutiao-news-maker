/* components/base/empty-state/empty-state.wxss - 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.icon-text {
  font-size: 80rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.empty-action {
  font-size: 28rpx;
  color: #E8002D;
  padding: 12rpx 32rpx;
  border: 2rpx solid #E8002D;
  border-radius: 36rpx;
}
