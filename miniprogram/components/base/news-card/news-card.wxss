/* components/base/news-card/news-card.wxss - 新闻卡片样式 */
.news-card {
  display: flex;
  padding: 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 2rpx;
  transition: background-color 0.2s;
}

.news-card:active {
  background-color: #F9F9F9;
}

/* 封面图 */
.card-cover {
  width: 220rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: #F5F5F5;
}

/* 内容区 */
.card-content {
  flex:1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

/* 标题 */
.card-title {
  font-size: 30rpx;
  color: #1A1A1A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
}

/* 底部信息 */
.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-tag {
  font-size: 20rpx;
  color: #E8002D;
  background-color: #FFF0F0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.view-count {
  font-size: 22rpx;
  color: #999999;
}

.time-text {
  font-size: 22rpx;
  color: #999999;
}
