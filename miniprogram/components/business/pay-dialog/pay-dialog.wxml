<!--components/business/pay-dialog/pay-dialog.wxml - 支付确认弹窗-->
<view wx:if="{{visible}}" class="pay-dialog-mask" bindtap="onMaskTap">
  <view class="pay-dialog-container" catchtap="preventBubble">
    <!-- 标题栏 -->
    <view class="dialog-header">
      <text class="dialog-title">{{title || '确认支付'}}</text>
      <view class="close-btn" bindtap="onCancel">×</view>
    </view>

    <!-- 内容区 -->
    <view class="dialog-body">
      <!-- 积分消耗信息 -->
      <view class="cost-info">
        <text class="cost-label">需消耗积分</text>
        <text class="cost-value">{{pointsCost}}</text>
      </view>

      <!-- 余额信息 -->
      <view class="balance-info">
        <text class="balance-label">当前余额</text>
        <text class="balance-value">{{pointsBalance}} 积分</text>
      </view>

      <!-- 余额不足提示 -->
      <view wx:if="{{pointsBalance < pointsCost}}" class="insufficient-tip">
        <text class="tip-text">积分余额不足，请先充值</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="dialog-footer">
      <button class="btn-cancel" bindtap="onCancel">取消</button>
      <button class="btn-confirm {{pointsBalance < pointsCost ? 'disabled' : ''}}" 
              bindtap="onConfirm"
              disabled="{{pointsBalance < pointsCost}}">
        确认支付 {{pointsCost}} 积分
      </button>
    </view>
  </view>
</view>
