/* pages/category/category.wxss - 题材库样式 */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background-color: #E8002D;
  flex-shrink: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex:1;
  font-size: 28rpx;
  height: 72rpx;
}

.placeholder {
  color: #999999;
}

.clear-btn {
  font-size: 32rpx;
  color: #999999;
  padding: 0 12rpx;
}

/* 内容布局 */
.content-layout {
  flex:1;
  display: flex;
  overflow: hidden;
}

/* 左侧导航 */
.left-nav {
  width: 200rpx;
  height: 100%;
  background-color: #F5F5F5;
  flex-shrink: 0;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 10rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.3s ease;
}

.nav-item.active {
  background-color: #FFFFFF;
  border-left-color: #E8002D;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-name {
  font-size: 26rpx;
  color: #666666;
}

.nav-item.active .nav-name {
  color: #E8002D;
  font-weight: bold;
}

/* 右侧内容 */
.right-content {
  flex:1;
  height: 100%;
  background-color: #FFFFFF;
}

/* 顶部Tab */
.content-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #EEEEEE;
  position: sticky;
  top: 0;
  background-color: #FFFFFF;
  z-index: 10;
}

.tab-item {
  flex:1;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  padding: 12rpx 0;
  position: relative;
}

.tab-item.active {
  color: #E8002D;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #E8002D;
  border-radius: 2rpx;
}

/* 内容列表 */
.content-list {
  padding: 20rpx;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #CCCCCC;
}
