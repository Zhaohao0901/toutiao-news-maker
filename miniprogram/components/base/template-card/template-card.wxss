/* components/base/template-card/template-card.wxss - 模板卡片样式 */
.template-card {
  position: relative;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.template-card:active {
  transform: scale(0.98);
}

/* 缩略图 */
.template-thumb {
  width: 100%;
  height: 240rpx;
  background-color: #F5F5F5;
}

/* 信息区 */
.template-info {
  padding: 16rpx;
}

.template-name {
  display: block;
  font-size: 26rpx;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.template-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.use-count {
  font-size: 20rpx;
  color: #999999;
}

.vip-tag {
  font-size: 18rpx;
  color: #FAAD14;
  background-color: #FFFBE6;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.points-tag {
  font-size: 18rpx;
  color: #E8002D;
  background-color: #FFF0F0;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

/* 选中标记 */
.selected-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #E8002D;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}
