/* components/business/ad-reward-btn/ad-reward-btn.wxss - 广告激励按钮样式 */
.ad-reward-container {
  margin: 20rpx;
}

.ad-btn {
  width: 100%;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  border: none;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.ad-btn.disabled {
  background: #CCCCCC;
}

.btn-content {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.btn-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.btn-text-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.btn-title {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.btn-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.btn-reward {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reward-points {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.reward-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}
