/* components/base/points-card/points-card.wxss - 积分卡片样式 */
.points-card {
  margin: 20rpx 24rpx;
}

.card-bg {
  background: linear-gradient(135deg, #E8002D 0%, #FF4D6A 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(232, 0, 45, 0.3);
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.points-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.points-value-area {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.points-number {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1;
  margin-right: 8rpx;
}

.points-unit {
  font-size: 28rpx;
  opacity: 0.8;
}

.points-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 34rpx;
  border: none;
}

.sign-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.recharge-btn {
  background: #FFFFFF;
  color: #E8002D;
  font-weight: bold;
}
